# RPC_WS_URL can be an Alchemy, dRPC, or public endpoint.
# Default public RPC works, but a private one is recommended for stability.
# Example: wss://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
RPC_WS_URL=wss://eth.public-rpc.com/ws

# Database connection
DATABASE_URL=postgresql://admin:password@127.0.0.1:5433/pump_ai
